{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SVIL Baduk",
  "version": "0.7.5",
  "identifier": "kr.svil.baduk",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SVIL Baduk",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "SVIL",
    "shortDescription": "고대비 바둑 — AI 대국",
    "longDescription": "저시력자를 위한 고대비 바둑. AI 대국, 배우기, P2P 대국.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "signCommand": "cmd.exe /c sign-windows.cmd %1"
    }
  }
}
