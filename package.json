{
  "name": "svil-baduk",
  "private": true,
  "version": "0.5.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:gh": "tsc -b && vite build --base /svil-baduk/",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "katago:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-katago.ps1",
    "katago:bridge": "node scripts/katago-bridge.mjs",
    "dev:all": "powershell -ExecutionPolicy Bypass -File scripts/dev-all.ps1",
    "start:app": "powershell -ExecutionPolicy Bypass -File scripts/start-app.ps1",
    "shortcut": "powershell -ExecutionPolicy Bypass -File scripts/install_desktop_shortcut.ps1",
    "deploy": "npm run build:gh && gh-pages -d dist -b gh-pages"
  },
  "dependencies": {
    "peerjs": "^1.5.4",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "gh-pages": "^6.3.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
